  "grammar_patterns": [
    {
      "pattern": "〜なければなりません",
      "reading": "nakereba narimasen",
      "meaning": "must do / have to",
      "formation": "Verb (nai-form) + ければなりません",
      "examples": [
        {
          "japanese": "明日五時に起きなければなりません",
          "reading": "Ashita go-ji ni okinakereba narimasen",
          "english": "I must wake up at 5 o'clock tomorrow"
        },
        {
          "japanese": "勉強しなければなりません",
          "reading": "Benkyou shinakereba narimasen",
          "english": "I must study"
        },
        {
          "japanese": "薬を飲まなければなりません",
          "reading": "Kusuri wo nomanakereba narimasen",
          "english": "I must take medicine"
        }
      ]
    },
    {
      "pattern": "〜なければならない",
      "reading": "nakereba naranai",
      "meaning": "must do (casual form)",
      "formation": "Verb (nai-form) + ければならない",
      "examples": [
        {
          "japanese": "早く起きなければならない",
          "reading": "Hayaku okinakereba naranai",
          "english": "I must wake up early"
        }
      ]
    },
    {
      "pattern": "〜なきゃ",
      "reading": "nakya",
      "meaning": "gotta do (very casual)",
      "formation": "Verb (nai-form) without い + きゃ",
      "examples": [
        {
          "japanese": "行かなきゃ",
          "reading": "Ikanakya",
          "english": "I gotta go"
        }
      ]
    }
  ],
